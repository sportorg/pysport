{
  "plansDirectory": "./doc/plans",
  "enableAllProjectMcpServers": true,
  "permissions": {
    "allow": [
      "Bash(uv:*)", 
      "Bash(git:*)", 
      "Edit(tests/**)",
      "Edit(pysport/**)",
      "Bash(openspec new:*)",
      "Bash(openspec status:*)",
      "Bash(openspec instructions:*)"
    ],
    "deny": [
      "Read(.env*)"
    ]
  },
  "env": {
    "ENABLE_TOOL_SEARCH": "auto:5"
  }
}
